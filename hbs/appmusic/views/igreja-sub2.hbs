    <title>Igreja - Sub2 | Igreja</title>
    <link rel="stylesheet" href="/stylesheets/style.css">

    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: #f5f5f5;
        }

        header {
            background: #2c3e50;
            color: white;
            padding: 25px;
            text-align: center;
