<!DOCTYPE html>
<html>
  <head>
    <title>{{title}} - Igreja</title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
        body {
            margin: 0;
            font-family: Arial, Helvetica, sans-serif;
            background: #f5f5f5;
        }

        header {
            background: #2c3e50;
            color: white;
            padding: 25px;
            text-align: center;
        }

        nav {
            background: #1a252f;
            padding: 10px;
            text-align: center;
        }

        nav a {
            color: white;
            margin: 0 15px;
            text-decoration: none;
            font-weight: bold;
        }

        nav a:hover {
            color: #f1c40f;
        }

        main {
            padding: 30px;
            max-width: 1000px;
            margin: auto;
            background: white;
            margin-top: 20px;
            border-radius: 8px;
        }

        .agenda {
            margin-top: 30px;
            padding: 20px;
            background: #ecf0f1;
            border-radius: 8px;
        }

        footer {
            margin-top: 40px;
            background: #1a252f;
            color: white;
            text-align: center;
            padding: 20px;
        }
    </style>
  </head>
  <body>
    {{{body}}}
  </body>
</html>
